# Neon Database Configuration
NEON_DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Environment Configuration
NODE_ENV=development

# API URLs
VITE_API_BASE_URL=http://localhost:5000
VITE_PRODUCTION_API_URL=https://api.example.com

# Frontend URLs
VITE_APP_URL=http://localhost:5174
VITE_PRODUCTION_URL=https://example.com

# Admin Configuration
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password
ADMIN_NAME=Admin

# Backend Configuration
PORT=5000

# JWT Secret - CHANGE THIS to a strong random value
JWT_SECRET=change-this-to-a-strong-random-secret

# Cloudflare R2 Configuration
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-key
CLOUDFLARE_R2_BUCKET_NAME=your-bucket
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://your-public-url.r2.dev

# CORS Configuration
CORS_ORIGIN=http://localhost:5174

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your-google-client-id
