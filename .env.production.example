# Production Environment Configuration (TEMPLATE - copy to .env.production and fill in)

# Database Connection (Neon PostgreSQL)
NEON_DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Worker Database URL (used by the serverless worker)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Admin Authentication
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-strong-admin-password
ADMIN_NAME=Admin

# JWT Secret - USE A STRONG RANDOM VALUE (min 32 characters)
JWT_SECRET=change-this-to-a-strong-random-secret
VITE_JWT_SECRET=change-this-to-a-strong-random-secret

# Cloudflare R2 Configuration
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-key
CLOUDFLARE_R2_BUCKET_NAME=your-bucket
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://your-public-url.r2.dev

# CORS
CORS_ORIGIN=https://your-domain.com

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# SEO
VITE_SITE_URL=https://your-domain.com
VITE_SITE_NAME=Your Site Name
VITE_SITE_DESCRIPTION=Your site description
VITE_SITE_KEYWORDS=keyword1, keyword2

# Google Services
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_GTM_CONTAINER_ID=GTM-XXXXXXX
VITE_GOOGLE_SITE_VERIFICATION=your-verification-code
VITE_BING_SITE_VERIFICATION=your-verification-code

# Social Media
VITE_INSTAGRAM_USERNAME=your-instagram

# Contact
VITE_PHONE_NUMBER=+91-XXXXXXXXXX
VITE_EMAIL=contact@example.com
VITE_BUSINESS_ADDRESS=City, State, India

# Geo Location
VITE_LATITUDE=17.3850
VITE_LONGITUDE=78.4867
VITE_CITY=Hyderabad
VITE_STATE=Telangana
VITE_COUNTRY=IN
VITE_COUNTRY_NAME=India

# Production URLs
VITE_API_BASE_URL=https://api.your-domain.com
VITE_APP_URL=https://your-domain.com

# DB Proxy (if using Cloudflare Workers tunnel)
DATABASE_PROXY_URL=https://your-db-proxy.workers.dev
DB_PROXY_TOKEN=your-db-proxy-token

# Environment
NODE_ENV=production
